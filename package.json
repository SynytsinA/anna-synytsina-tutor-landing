{
  "name": "anna-synytsina-tutor-landing",
  "version": "1.1.0",
  "description": "Персональний лендинг вчителя початкових класів та репетитора Анни Синиціної",
  "author": "Artem Synytsin",
  "homepage": "https://anna-tutor.com.ua",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && stylelint \"**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "validate": "npm run lint && npm run type-check && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.4",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
